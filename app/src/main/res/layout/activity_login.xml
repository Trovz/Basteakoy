<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="600dp">

        <!-- ── LOGO SECTION ─────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/logoSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="56dp"
            android:paddingBottom="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/loginLogo"
                android:layout_width="350dp"
                android:layout_height="170dp"
                android:src="@drawable/logo1"
                android:contentDescription="Basteakoy Logo"/>





        </LinearLayout>

        <!-- ── FORM CARD ────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/formCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/logoSection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Cashier ID -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilCashierId"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxStrokeColor="@color/input_stroke_color"
                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#888888"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCashierId"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="cashier id"
                        android:inputType="number"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:textColorHint="#AAAAAA"
                        android:imeOptions="actionNext"
                        android:maxLength="10"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    app:boxStrokeColor="@color/input_stroke_color"
                    app:boxStrokeWidth="1.5dp"
                    app:hintTextColor="#888888"
                    app:endIconMode="password_toggle"
                    app:endIconTint="#AAAAAA"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="password"
                        android:inputType="textPassword"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:textColorHint="#AAAAAA"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Error message -->
                <TextView
                    android:id="@+id/tvLoginError"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#D32F2F"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"/>

                <!-- LOGIN button -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:text="Login"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/yellow"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"/>

                <!-- Loading progress (hidden by default) -->
                <ProgressBar
                    android:id="@+id/loginProgress"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"
                    android:indeterminateTint="#FFBB00"
                    android:visibility="gone"/>

                <!-- Forget Password -->
                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="10dp"
                    android:text="forget password?"
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── SIGN UP LINK ───────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/signUpRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/formCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New here? "
                android:textSize="13sp"
                android:textColor="#777777"/>
            <TextView
                android:id="@+id/tvSignUp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create an account"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFBB00"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <!-- ── ADMIN LOGIN BUTTON ─────────────────────────────────────── -->
        <Button
            android:id="@+id/btnAdminLogin"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="36dp"
            android:text="ADMINISTRATOR LOGIN"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:textColor="#FFFFFF"
            android:stateListAnimator="@null"
            android:backgroundTint="@color/dark_card"
            android:elevation="0dp"
            app:layout_constraintTop_toBottomOf="@id/signUpRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
