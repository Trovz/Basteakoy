<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Product Image -->
        <ImageView
            android:id="@+id/manageItemImage"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/baseline_fastfood_24"
            android:scaleType="centerCrop"
            android:background="#F5F5F5"
            android:contentDescription="Product"/>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/manageItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Product Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#222222"/>

            <TextView
                android:id="@+id/manageItemCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="12sp"
                android:textColor="#FFBB00"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/manageItemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textSize="12sp"
                android:textColor="#777777"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Delete Button -->
        <ImageButton
            android:id="@+id/btnDeleteProduct"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#D32F2F"
            android:contentDescription="Delete product"
            android:padding="8dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
